# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Model ─────────────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-6
MAX_TOKENS=8192

# ── Output ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output

# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_CLUSTER=devnet
ANCHOR_VERSION=0.31.0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
